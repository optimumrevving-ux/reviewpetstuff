{
  "version": 2,
  "buildCommand": "echo 'Static HTML - skipping build'",
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "framework": null,
  "rewrites": [
    { "source": "/:path*", "destination": "/:path.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}